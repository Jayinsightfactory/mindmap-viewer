# ─────────────────────────────────────────────────────────────────────────────
# Orbit AI — 환경변수 예시
# 이 파일을 복사해서 .env 로 저장 후 실제 값 입력
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# 서버
PORT=4747
NODE_ENV=production

# 인증 (1 = 인증 없이 로컬 전용 모드)
AUTH_DISABLED=0
SESSION_SECRET=your-random-session-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Kakao OAuth
KAKAO_CLIENT_ID=

# Naver OAuth
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Apple OAuth (Apple Developer 계정 필요 — p8 키 내용을 \n으로 이스케이프해서 입력)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# OAuth 콜백 베이스 URL (배포 도메인)
OAUTH_CALLBACK_BASE=https://your-domain.com
CLIENT_ORIGIN=https://your-domain.com

# Toss Payments (없으면 MOCK 모드)
TOSS_SECRET_KEY=

# Claude API — 콘텐츠 분석 + 인사이트 + 학습 가이드 (필수)
ANTHROPIC_API_KEY=

# 인사이트 생성 주기 (ms, 기본 1시간)
INSIGHT_INTERVAL_MS=3600000

# 인사이트 엔진 선택 (ollama | claude | 미설정 시 규칙 기반)
# claude: ANTHROPIC_API_KEY 사용 / ollama: 로컬 Ollama 사용
INSIGHT_ENGINE=

# Ollama 로컬 LLM (미설정 시 http://localhost:11434)
OLLAMA_URL=http://localhost:11434
# 커스텀 모델 학습 베이스 모델 (미설정 시 llama3.2)
OLLAMA_BASE_MODEL=llama3.2
# 인사이트에 사용할 Ollama 모델 (미설정 시 llama3.2 또는 학습된 orbit-insight 자동 사용)
OLLAMA_MODEL=

# GitHub Webhook 서명 검증 시크릿
GITHUB_WEBHOOK_SECRET=

# 데이터베이스 (미설정 시 SQLite 자동 사용)
# DATABASE_URL=postgresql://user:pass@host:5432/orbitdb

# MCP 서버 인증 토큰 (미설정 시 localhost에서 인증 없이 접근 가능)
MCP_AUTH_TOKEN=
