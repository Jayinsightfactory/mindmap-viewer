# ──────────────────────────────────────────
# Claude Work MindMap — 환경변수 설정
# cp .env.example .env 후 값 수정
# ──────────────────────────────────────────

# 서버 포트 (기본: 4747)
PORT=4747

# 채널 설정 (팀원과 같은 채널명 입력 시 실시간 공유)
MINDMAP_PORT=4747
MINDMAP_CHANNEL=default
MINDMAP_MEMBER=내이름

# DB 경로 (기본: ./data/mindmap.db)
# DB_PATH=./data/mindmap.db

# PostgreSQL (SQLite 대신 PG 사용 시)
# DATABASE_URL=postgresql://user:password@localhost:5432/mindmap

# 배포 환경 (production | development)
# NODE_ENV=development
