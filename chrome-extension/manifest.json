{
  "manifest_version": 3,
  "name": "Orbit — AI 대화 수집기",
  "version": "2.0.0",
  "description": "ChatGPT, Claude, Gemini 등 AI 대화를 자동 수집하여 3D 마인드맵으로 시각화합니다. 데이터는 로컬 우선 저장.",
  "homepage_url": "https://github.com/dlaww-wq/mindmap-viewer",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "storage", "alarms", "scripting"],
  "host_permissions": [
    "http://localhost/*",
    "https://*.up.railway.app/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://www.bing.com/*",
    "https://copilot.microsoft.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/chat*",
        "https://www.bing.com/search*"
      ],
      "js": ["content-ai.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Orbit AI 대화 수집기",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
