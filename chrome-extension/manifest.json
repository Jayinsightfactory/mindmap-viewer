{
  "manifest_version": 3,
  "key": "",
  "name": "Orbit — 업무 학습 수집기",
  "version": "2.1.0",
  "description": "업무 웹앱(ERP 등) 작업과 AI 대화를 자동 수집하여 업무 절차를 학습합니다. 업무 도메인 한정, 데이터는 로컬 우선.",
  "homepage_url": "https://github.com/Jayinsightfactory/mindmap-viewer",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "storage", "alarms", "scripting"],
  "storage": { "managed_schema": "managed_schema.json" },
  "host_permissions": [
    "http://localhost/*",
    "https://*.up.railway.app/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://www.bing.com/*",
    "https://copilot.microsoft.com/*",
    "https://*.ecount.com/*",
    "https://*.nenovaweb.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/chat*",
        "https://www.bing.com/search*"
      ],
      "js": ["content-ai.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.ecount.com/*",
        "https://*.nenovaweb.com/*"
      ],
      "js": ["content-work.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Orbit AI 대화 수집기",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
