{
  "name": "orbit-ai",
  "version": "2.0.0",
  "description": "AI 작업 흐름 실시간 시각화 + 하네스 시스템 — Claude Code, Cursor, Windsurf, VS Code 지원",
  "bin": {
    "orbit": "./bin/orbit.js"
  },
  "keywords": [
    "claude-code", "ai", "mindmap", "visualization", "real-time",
    "hooks", "cursor", "windsurf", "llm", "developer-tools"
  ],
  "homepage": "https://github.com/dlaww-wq/mindmap-viewer",
  "repository": {
    "type": "git",
    "url": "https://github.com/dlaww-wq/mindmap-viewer.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "install:macos": "bash setup/install.sh",
    "install:win": "powershell -ExecutionPolicy Bypass -File setup\\install.ps1",
    "docker:build": "docker build -t mindmap-viewer .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "chokidar": "^3.6.0",
    "express": "^4.18.2",
    "ulid": "^3.0.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "jest": "^30.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  }
}
