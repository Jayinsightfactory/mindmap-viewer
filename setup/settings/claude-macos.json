{
  "_comment": "Claude Code 훅 설정 — macOS/Linux용. MINDMAP_PATH를 실제 경로로 교체하세요.",
  "_usage": "cp setup/settings/claude-macos.json ~/.claude/settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node MINDMAP_PATH/save-turn.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node MINDMAP_PATH/save-turn.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node MINDMAP_PATH/save-turn.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node MINDMAP_PATH/save-turn.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node MINDMAP_PATH/save-turn.js"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node MINDMAP_PATH/save-turn.js"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node MINDMAP_PATH/save-turn.js"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node MINDMAP_PATH/save-turn.js"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node MINDMAP_PATH/save-turn.js"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node MINDMAP_PATH/save-turn.js"
          }
        ]
      }
    ]
  }
}
